[MASTER]
jobs=0
ignore-paths=^agent_api/migrations/.*$

[TYPECHECK]
# Avoid noisy unresolved imports from environment/editor mismatch.
ignored-modules=django,rest_framework,pytest

[MESSAGES CONTROL]
disable=
	import-error,
	missing-module-docstring,
	missing-class-docstring,
	missing-function-docstring,
	too-few-public-methods,
	redefined-outer-name,
	unused-argument

[FORMAT]
max-line-length=120

[BASIC]
good-names=i,j,k,pk,db,qs

[REPORTS]
score=no
